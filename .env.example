# Variables no secretas del Worker de Cloudflare Pages
ENTRA_ENABLED=false
ENTRA_CLIENT_ID=
ENTRA_TENANT_ID=
ENTRA_AUTHORITY=https://login.microsoftonline.com/TENANT_ID
ENTRA_REDIRECT_URI=https://portal-jornadas.pages.dev/api/auth/microsoft/callback
ENTRA_POST_LOGOUT_REDIRECT_URI=https://portal-jornadas.pages.dev/?signed_out=1
ENTRA_REQUIRED_ROLE=PortalJornadas.Access
LOCAL_ADMIN_LOGIN_ENABLED=true

# Secreto exclusivo del backend. Configurarlo cifrado en Cloudflare; nunca en el frontend ni en Git.
ENTRA_CLIENT_SECRET=
